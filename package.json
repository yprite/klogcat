{
  "name": "klogcat",
  "version": "0.0.6",
  "private": false,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "push": "scripts/strict-push.sh",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "build": "tsc && vite build",
    "test": "vitest run",
    "test:unit": "node scripts/harness/run-test-layer.mjs unit",
    "test:scenario": "node scripts/harness/run-test-layer.mjs scenario",
    "test:scenario:coverage": "node scripts/harness/run-test-layer.mjs scenario --coverage",
    "test:coverage": "node scripts/harness/run-coverage.mjs",
    "test:e2e": "node scripts/harness/run-e2e.mjs",
    "test:watch": "vitest",
    "tauri": "tauri",
    "metrics:precommit": "scripts/harness/metrics-pre-commit.sh",
    "metrics:prepush": "scripts/harness/metrics-pre-push.sh",
    "security:license": "node scripts/harness/security-license.mjs",
    "harness:precommit": "scripts/harness/pre-commit.sh",
    "harness:prepush": "scripts/harness/pre-push.sh",
    "start": "node ./bin/klogcat.js",
    "klogcat:build": "node ./bin/klogcat.js --build-only",
    "klogcat:dev": "node ./bin/klogcat.js --dev"
  },
  "dependencies": {
    "@tanstack/react-virtual": "^3.14.3",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/cli": "^2.11.3",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.15",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^3.4.19",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.1.9"
  },
  "description": "Tauri desktop log tailer for Kubernetes pod log files",
  "bin": {
    "klogcat": "./bin/klogcat.js"
  },
  "exports": {
    "./sdk/log-viewer": {
      "types": "./src/sdk/log-viewer.ts",
      "default": "./src/sdk/log-viewer.ts"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/yprite/klogcat.git"
  },
  "license": "UNLICENSED"
}
